{
  "name": "backend",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "test:unit": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
